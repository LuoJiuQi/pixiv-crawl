# 本地运行时可以保留 false，方便看到浏览器。
# Docker 里更建议用 true，docker-compose 已经会覆盖成 true。
PIXIV_USERNAME=
PIXIV_PASSWORD=
HEADLESS=false
# 如果所在网络无法直接访问 Pixiv，可填写代理。
# 例子：
# PROXY_SERVER=http://127.0.0.1:7890
# PROXY_SERVER=socks5://127.0.0.1:7890
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
TIMEOUT=30000
SAVE_DEBUG_ARTIFACTS=false
VERBOSE_DEBUG_OUTPUT=false
DOWNLOAD_DIR=./data/images
DOWNLOAD_TIMEOUT_SECONDS=60
DOWNLOAD_RETRY_ATTEMPTS=3
DOWNLOAD_RETRY_BACKOFF_SECONDS=1
STATE_FILE=./data/state/storage_state.json
DB_PATH=./data/pixiv.db
LOG_PATH=./logs/app.log
# 可选：控制日志滚动大小和保留份数。
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
# 可选：开启内置定时抓取。
# 开启后，直接执行 `python main.py` 会在每天指定时间自动跑一次关注列表更新。
SCHEDULED_RUN_ENABLED=false
# 24 小时制，固定写成 HH:MM。
SCHEDULED_RUN_TIME=02:00
# 可选：定时更新成功后，再自动补跑一次失败重试。
SCHEDULED_RETRY_FAILED_ENABLED=false
# 可选：定时失败重试时最多处理多少条失败记录。
SCHEDULED_RETRY_FAILED_LIMIT=20
# 可选：定时任务每轮执行后的 JSON 报告输出目录。
SCHEDULED_REPORT_OUTPUT_DIR=./data/exports/scheduled-reports
